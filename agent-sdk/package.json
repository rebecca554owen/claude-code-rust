{
  "name": "@srothgan/claude-rs-agent-bridge",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "NDJSON bridge between claude-code-rust and the Claude Agent SDK",
  "main": "dist/bridge.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/bridge.js",
    "check": "npm run build",
    "lint": "biome lint src",
    "knip": "knip --include files,dependencies,unlisted,unresolved",
    "audit": "node ./scripts/audit-direct-deps.mjs",
    "audit:raw": "npm audit --audit-level=moderate",
    "test": "npm run build && node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.146",
    "@anthropic-ai/sdk": "0.97.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "25.3.3",
    "knip": "6.4.1",
    "typescript": "5.9.3"
  }
}
